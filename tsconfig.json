{
	"compilerOptions": {
		"target": "ES2022",
		"module": "CommonJS",
		"rootDir": "./src",
		"outDir": "./dist",
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"strict": true,
		"skipLibCheck": true,
		"verbatimModuleSyntax": false,
		"types": ["node"]
	},

	// REVERT TO THIS:
	"include": ["src/**/*"],
	"exclude": ["node_modules", "generated", "dist"]
}
