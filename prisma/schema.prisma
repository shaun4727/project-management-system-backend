generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  MANAGER
  MEMBER
}

model User {
  id         String   @id @default(uuid())
  name       String
  email      String   @unique
  password   String
  role       Role     @default(MEMBER)
  department String?
  skills     String[] // PostgreSQL string array
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}